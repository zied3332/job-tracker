{% extends 'base_auth.html.twig' %}

{% block title %}Forgot Password{% endblock %}

{% block body %}
<div class="card shadow-sm p-4 rounded" style="max-width: 420px; margin: auto;">
    <h2 class="text-center mb-3">Forgot your password?</h2>
    <p>Enter your username (email) to receive a 6-digit reset code.</p>

    {# SHOW FLASH MESSAGES #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <form method="post" action="{{ path('app_forgot_password') }}">
        <div class="mb-3">
            <label for="username" class="form-label">Username (email)</label>
            <input type="text" name="username" id="username" class="form-control" required>
        </div>

        {# CSRF PROTECTION #}
        <input type="hidden" name="_token" value="{{ csrf_token('forgot_password') }}">

        <div class="d-grid">
            <button type="submit" class="btn btn-primary">Send Code</button>
        </div>
    </form>
</div>
{% endblock %}
