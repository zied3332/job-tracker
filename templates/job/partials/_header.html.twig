<div class="dashboard-header d-flex justify-content-between align-items-center mb-3">
    <div class="dashboard-title">Job Dashboard</div>
    <div class="dropdown">
        <button class="btn btn-success dropdown-toggle" data-bs-toggle="dropdown">Export</button>
        <ul class="dropdown-menu">
           
            <li>
                <a class="dropdown-item" href="{{ path('job_export_excel') }}">Excel</a>
            </li>
        </ul>
    </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.dropdown-item').forEach(link => {
        link.addEventListener('click', function (e) {
            const confirmExport = confirm(`Are you sure you want to export to ${this.textContent.trim()}?`);
            if (!confirmExport) {
                e.preventDefault();
            }
        });
    });
});
</script>
