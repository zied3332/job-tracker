<div class="modal fade" id="editModal{{ job.id }}" tabindex="-1" aria-labelledby="editModalLabel{{ job.id }}" aria-hidden="true">
	<div class="modal-dialog modal-md modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">Edit Job #{{ job.jobNumber }}</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body">
				<form class="ajax-edit-form" data-id="{{ job.id }}">
					<div class="row g-3">
						<div class="col-md-6">
							<label class="form-label">Claim Number</label>
							<input type="text" name="claimNumber" value="{{ job.claimNumber }}" class="form-control">
						</div>
						<div class="col-md-6">
							<label class="form-label">Address</label>
							<input type="text" name="address" value="{{ job.address }}" class="form-control">
						</div>
						<div class="col-md-6">
							<label class="form-label">City</label>
							<input type="text" name="city" value="{{ job.city }}" class="form-control">
						</div>
						<div class="col-md-6">
							<label class="form-label">State</label>
							<input type="text" name="state" value="{{ job.state }}" class="form-control">
						</div>
						<div class="col-md-6">
							<label class="form-label">Status</label>
							<input type="text" name="status" value="{{ job.status }}" class="form-control">
						</div>
						<div class="col-md-6">
							<label class="form-label">Category</label>
							<input type="text" name="category" value="{{ job.category }}" class="form-control">
						</div>
						<div class="col-md-12">
							<label class="form-label">Project Manager</label>
							<input type="text" name="projectManager" value="{{ job.projectManager }}" class="form-control">
						</div>
						<div class="col-md-6">
							<label class="form-label">Name</label>
							<input type="text" name="name" value="{{ job.name }}" class="form-control">
						</div>
						<div class="col-md-6">
							<label class="form-label">Customer</label>
							<input type="text" name="customer" value="{{ job.customer }}" class="form-control">
						</div>
						<div class="col-md-12">
							<label class="form-label">Description</label>
							<textarea name="description" class="form-control" rows="3">{{ job.description }}</textarea>
						</div>
						<div class="col-md-12">
							<label class="form-label">Company</label>
							<select name="company" class="form-select">
								{% for company in companies %}
									<option value="{{ company.id }}" {% if job.company and job.company.id == company.id %} selected {% endif %}>
										{{ company.name }}
									</option>
								{% endfor %}
							</select>
						</div>
					</div>
					<div class="mt-3 text-end">
						<button type="submit" class="btn btn-success">Save changes</button>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
	document.querySelectorAll('.ajax-edit-form').forEach(form => {
		form.addEventListener('submit', async function (e) {
			e.preventDefault();

			const jobId = this.dataset.id;
			const formData = new FormData(this);
			const data = {};
			formData.forEach((value, key) => data[key] = value);

			console.log('Submitting data:', data); // Debugging

			const response = await fetch(`/jobs/ajax-edit/${jobId}`, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'X-Requested-With': 'XMLHttpRequest'
				},
				body: JSON.stringify(data)
			});

			let result;
			try {
				result = await response.json();
			} catch (e) {
				console.error("Invalid JSON response:", await response.text());
				alert("Unexpected server response.");
				return;
			}

			this.querySelectorAll('.form-error').forEach(el => el.remove());
			this.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));

			if (result.success) {
				const modalElement = this.closest('.modal');
				const instance = bootstrap.Modal.getInstance(modalElement);
				if (instance) instance.hide();
				location.reload();
			} else if (result.errors) {
				for (const [field, message] of Object.entries(result.errors)) {
					const input = this.querySelector(`[name="${field}"]`);
					if (input) {
						input.classList.add('is-invalid');
						const errorDiv = document.createElement('div');
						errorDiv.className = 'form-error text-danger mt-1';
						errorDiv.textContent = message;
						input.parentNode.appendChild(errorDiv);
					}
				}
			}
		});
	});
});
</script>
