{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .dashboard-container {
            max-width: 95%;
            margin: 40px auto;
            padding: 20px;
        }
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .dashboard-title {
            font-size: 2rem;
            font-weight: bold;
        }
        th,
        td {
            text-align: center;
            vertical-align: middle;
        }
        .btn-sm {
            margin: 2px;
        }
        .filter-bar {
            margin-bottom: 20px;
            display: flex;
            gap: 10px;
        }
        .pagination-bar {
            display: flex;
            justify-content: center;
            margin-top: 20px;
        }
        .pagination-bar button {
            margin: 0 5px;
        }
        .hidden-row {
            display: none;
        }
        .status-toggle {
            display: flex;
            justify-content: center;
            margin-bottom: 20px;
        }
        .status-toggle .btn {
            margin: 0 5px;
            min-width: 80px;
        }
        .status-toggle .btn.active {
            font-weight: bold;
        }
        .form-error {
            font-size: 0.875rem;
            color: #e74c3c;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="dashboard-container">
        {# Header and filter controls #}
        {% include 'job/partials/_header.html.twig' %}



        {# Table and Load More #}
{% include 'job/partials/_table.html.twig' with {
    jobs: jobs,
    companies: companies,
    page: 1,
    totalPages: 1
} %}

{% include 'job/partials/_pagination.html.twig' with {
    page: page,
    totalPages: totalPages
} %}


{% include 'job/partials/_delete_modal.html.twig' %}



        {# Global delete modal #}




    </div>
{% endblock %}
